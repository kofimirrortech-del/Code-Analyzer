# PostgreSQL connection string (from Neon, Supabase, or Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/deffizzy

# Random secret for signing session cookies (generate a strong random string)
SESSION_SECRET=change-this-to-a-long-random-secret

# Google OAuth credentials (from Google Cloud Console)
# Required for Google Drive backup feature
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Your deployed app URL on Render (used for Google OAuth redirect)
# Example: https://deffizzy-erp.onrender.com
APP_URL=https://your-app-name.onrender.com

# Port (Render sets this automatically; leave as 3000 for local dev)
PORT=3000
